inset=c(-0.35,0),
legend=c(
expression(Model~I~~eta==0.5),
expression(Model~I~~eta==0.95),
expression(Model~I~~eta==1.05),
expression(Model~I~~eta==2.5),
expression(Model~II~~eta==0.5),
expression(Model~II~~eta==0.95),
expression(Model~II~~eta==1.05),
expression(Model~II~~eta==2.5)
),
col=rep(cols,2),
lty=c(rep(1,4),rep(2,4)),
pch=c(rep(16,4),rep(17,4)),
bty="n",
cex=0.8)
dev.off()
}
