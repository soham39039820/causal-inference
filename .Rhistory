ylim=ylim_range,
xlab="Severity level (m)",
ylab=expression(Optimal~Order~Quantity~(Q^"*")),
main=qname)
# Model I (solid)
for(i in 2:4){
lines(m_vals, Q_vol[i,], type="o",
col=cols[i], pch=16, lwd=2)
}
# Model II (dashed)
for(i in 1:4){
lines(m_vals, Q_novol[i,], type="o",
col=cols[i], pch=17, lwd=2, lty=2)
}
##########################################################
