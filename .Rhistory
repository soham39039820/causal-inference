}
for(i in 1:4){
lines(m_vals, Q_novol[i,], type="o", pch=17, lwd=2, lty=2)
}
legend("topleft",
legend=c(paste("Vol, eta=",eta_labels),
paste("NoVol, eta=",eta_labels)),
lty=c(rep(1,4),rep(2,4)),
pch=c(rep(16,4),rep(17,4)),
bty="n",
cex=0.8)
dev.off()
}
