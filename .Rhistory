# Load required package
library(stats)
# Load required package
library(stats)
# True distribution: Gamma(25, 8)
F_cdf <- function(x) pgamma(x, shape = 25, rate = 8)
# Grid for evaluating KS distance
x_grid <- seq(0, 10, length.out = 2000)
# KS distance function
ks_distance <- function(G_cdf) {
max(abs(F_cdf(x_grid) - G_cdf(x_grid)))
}
lambda_vals <- seq(1, 20, length.out = 50)
exp_list <- lapply(lambda_vals, function(lambda) {
G_cdf <- function(x) pexp(x, rate = lambda)
d <- ks_distance(G_cdf)
list(cdf = G_cdf, dist = d, param = lambda)
})
# Sort by KS distance (monotone increasing)
exp_sorted <- exp_list[order(sapply(exp_list, function(x) x$dist))]
# ---------------------------
# 2. Log-normal family
# ---------------------------
meanlog_vals <- seq(-2, 2, length.out = 20)
sdlog_vals   <- seq(0.2, 1.5, length.out = 20)
lnorm_list <- list()
for (m in meanlog_vals) {
for (s in sdlog_vals) {
G_cdf <- function(x) plnorm(x, meanlog = m, sdlog = s)
d <- ks_distance(G_cdf)
lnorm_list[[length(lnorm_list) + 1]] <- list(
cdf = G_cdf,
dist = d,
param = c(m, s)
)
}
}
# Sort log-normal by KS distance
lnorm_sorted <- lnorm_list[order(sapply(lnorm_list, function(x) x$dist))]
# ---------------------------
# 3. Combine sequences
# ---------------------------
# First exponential, then log-normal
G_sequence <- c(exp_sorted, lnorm_sorted)
# Extract KS distances (should be increasing)
ks_values <- sapply(G_sequence, function(x) x$dist)
# Check monotonicity
is_monotone <- all(diff(ks_values) >= 0)
cat("Is KS sequence monotone increasing? ", is_monotone, "\n")
# Load required package
library(stats)
# ---------------------------
# True distribution: Gamma(25, 8)
# ---------------------------
F_cdf <- function(x) pgamma(x, shape = 25, rate = 8)
# Grid for evaluating KS distance
x_grid <- seq(0, 10, length.out = 2000)
# KS distance function
ks_distance <- function(G_cdf) {
max(abs(F_cdf(x_grid) - G_cdf(x_grid)))
}
# ---------------------------
# 1. Exponential family
# ---------------------------
lambda_vals <- seq(1, 20, length.out = 50)
exp_list <- lapply(lambda_vals, function(lambda) {
G_cdf <- function(x) pexp(x, rate = lambda)
d <- ks_distance(G_cdf)
list(cdf = G_cdf, dist = d, param = lambda)
})
# Sort by KS distance (monotone increasing)
exp_sorted <- exp_list[order(sapply(exp_list, function(x) x$dist))]
# Extract KS values (FINAL OBJECT 1)
ks_exp <- sapply(exp_sorted, function(x) x$dist)
# Extract corresponding parameters (optional but useful)
lambda_sorted <- sapply(exp_sorted, function(x) x$param)
# ---------------------------
# 2. Log-normal family
# ---------------------------
meanlog_vals <- seq(-2, 2, length.out = 20)
sdlog_vals   <- seq(0.2, 1.5, length.out = 20)
lnorm_list <- list()
for (m in meanlog_vals) {
for (s in sdlog_vals) {
G_cdf <- function(x) plnorm(x, meanlog = m, sdlog = s)
d <- ks_distance(G_cdf)
lnorm_list[[length(lnorm_list) + 1]] <- list(
cdf = G_cdf,
dist = d,
param = c(m, s)
)
}
}
# Sort log-normal by KS distance (monotone increasing)
lnorm_sorted <- lnorm_list[order(sapply(lnorm_list, function(x) x$dist))]
# Extract KS values (FINAL OBJECT 2)
ks_lnorm <- sapply(lnorm_sorted, function(x) x$dist)
# Extract parameters (optional)
lnorm_params <- t(sapply(lnorm_sorted, function(x) x$param))
colnames(lnorm_params) <- c("meanlog", "sdlog")
# ---------------------------
# 3. Sanity checks
# ---------------------------
cat("Exponential KS monotone? ", all(diff(ks_exp) >= 0), "\n")
cat("Log-normal KS monotone? ", all(diff(ks_lnorm) >= 0), "\n")
# ---------------------------
# 4. (Optional) Data frames for reporting
# ---------------------------
exp_df <- data.frame(
lambda = lambda_sorted,
ks = ks_exp
)
lnorm_df <- data.frame(
meanlog = lnorm_params[,1],
sdlog   = lnorm_params[,2],
ks = ks_lnorm
)
# View first few values
head(exp_df)
head(lnorm_df)
dim(exp_df)
dim(lnorm_df)
max(lnorm_df$ks)
max(exp_df$ks)
